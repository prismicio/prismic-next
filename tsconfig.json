{
	"compilerOptions": {
		"strict": true,
		"skipLibCheck": true,

		"target": "esnext",
		"module": "esnext",
		"declaration": true,
		"declarationMap": true,
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,

		"forceConsistentCasingInFileNames": true,
		"jsx": "react-jsx",
		"lib": ["esnext", "dom", "dom.iterable"],
		"types": ["react"]
	},
	"exclude": ["node_modules", "dist", "e2e-projects"]
}
